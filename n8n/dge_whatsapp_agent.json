        "jsCode": "let response = '';\ntry {\n  if ($json.candidates && $json.candidates[0] && $json.candidates[0].content) {\n    response = $json.candidates[0].content.parts[0].text;\n  } else {\n    response = \"¡Hola! Tuve un glitch digital. ¿Podrías repetirme lo último? Soy Sofía.\";\n  }\n} catch (e) {\n  response = \"¡Hola! Soy Sofía. ¿En qué podemos ayudarte hoy?\";\n}\n\nreturn {\n  response,\n  from: $('Construir Prompt con Memoria').item.json.from\n};"
