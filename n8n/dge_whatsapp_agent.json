    {
      "parameters": {
        "jsCode": "// Extracción indestructible para Evolution API v1/v2\nfunction findKey(obj, targetKey) {\n  if (!obj || typeof obj !== 'object') return undefined;\n  if (targetKey in obj && obj[targetKey] !== null && obj[targetKey] !== undefined) return obj[targetKey];\n  for (const k in obj) {\n    const res = findKey(obj[k], targetKey);\n    if (res !== undefined) return res;\n  }\n  return undefined;\n}\n\nconst payload = $input.item.json;\n\n// Ignorar mensajes enviados por nosotros mismos para evitar bucles\nconst fromMe = findKey(payload, 'fromMe');\nif (fromMe === true) return [];\n\nconst remoteJid = findKey(payload, 'remoteJid');\nif (!remoteJid || remoteJid.includes('@g.us')) return []; // Ignorar grupos\n\n// El texto puede estar en conversation o text\nlet messageText = findKey(payload, 'conversation') || findKey(payload, 'text') || '';\nif (!messageText) return [];\n\nconst pushName = findKey(payload, 'pushName') || 'Cliente';\n\n// Detectar paquete de interés\nlet paquete = 'General';\nif (messageText.includes('Web Sencilla')) paquete = 'Web Sencilla';\nelse if (messageText.includes('Web Pro')) paquete = 'Web Pro & Brand';\nelse if (messageText.includes('Tienda Online')) paquete = 'Tienda Online';\nelse if (messageText.includes('Agente de Ventas IA')) paquete = 'Agente IA';\nelse if (messageText.includes('Logotipo')) paquete = 'Logotipo Épico';\nelse if (messageText.includes('Manual de Marca')) paquete = 'Manual de Marca';\n\nreturn {\n  from: remoteJid,\n  pushName,\n  messageText,\n  paquete,\n  timestamp: new Date().toISOString()\n};"
      },
